# Configuración SMTP para envío de emails de citas
# Copia este archivo como .env.local y completa los valores

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password-de-gmail

# Email donde llegan las notificaciones de citas
CONTACT_EMAIL=notaryaplus3_1@yahoo.com

# ---------------------------------------------------------------
# Google Analytics 4 (opcional, solo si queres trackear visitantes)
# ---------------------------------------------------------------
# Measurement ID de GA4. Se crea en analytics.google.com y tiene
# el formato G-XXXXXXXXXX. Debe existir TAMBIEN como secret en
# GitHub Actions (Repository secrets) para que se inline en el build.
# Si queda vacio, el componente <GoogleAnalytics /> no renderiza nada.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
