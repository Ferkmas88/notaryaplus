# ============================================
# Security Headers — notaryaplus.com
# Digital AM — 2026-04-09
# ============================================

# HSTS — Fuerza HTTPS por 1 año, evita ataques de downgrade en WiFi pública
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

# Clickjacking — impide que el sitio sea embebido en iframes externos maliciosos
Header always set X-Frame-Options "SAMEORIGIN"

# MIME Sniffing — evita que el browser ejecute archivos con tipo incorrecto
Header always set X-Content-Type-Options "nosniff"

# Referrer — limita qué información de URL se comparte con terceros
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions — deshabilita acceso a cámara, micrófono y geolocalización
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

# XSS Protection — capa extra para browsers viejos
Header always set X-XSS-Protection "1; mode=block"

# CSP — permite Google Fonts, Maps, Google Analytics (GA4 + GTM), WhatsApp, y el bot de Railway
# - script-src:   GTM (googletagmanager.com) carga el loader de GA4 y Maps JS.
# - img-src:      GA4 usa beacons GIF hacia google-analytics.com + region1.
# - connect-src:  GA4 manda hits por fetch/XHR a google-analytics.com, analytics.google.com,
#                 region1.google-analytics.com, y el bot de Railway para el ChatWidget.
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' maps.googleapis.com maps.gstatic.com www.googletagmanager.com www.google-analytics.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com data:; frame-src www.google.com maps.google.com calendar.google.com; img-src 'self' data: blob: maps.gstatic.com maps.googleapis.com *.googleapis.com www.googletagmanager.com www.google-analytics.com *.google-analytics.com; connect-src 'self' maps.googleapis.com https://web-production-c32f8.up.railway.app https://www.google-analytics.com https://analytics.google.com https://*.analytics.google.com https://*.google-analytics.com;"

# ============================================
# Cache
# ============================================

# No cachear HTML
<FilesMatch "\.(html)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires 0
</FilesMatch>

# JS, CSS y fonts: cache largo (assets con hash en nombre)
<FilesMatch "\.(js|css|woff2|woff|ttf|svg|ico|png|jpg|jpeg|webp)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
